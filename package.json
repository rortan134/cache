{
    "name": "cache",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "packageManager": "bun@1.3.11",
    "scripts": {
        "clean": "find . -name node_modules -o -name .next -o -name .swc -o -name tsconfig.buildinfo -type d -prune | xargs rm -rf",
        "dev": "next dev",
        "build": "npx gt translate && next build",
        "start": "next start",
        "db-deploy": "prisma migrate deploy",
        "postinstall": "prisma generate",
        "db-migrate": "prisma migrate dev",
        "lint": "ultracite check",
        "lint:fix": "ultracite fix",
        "type-check": "tsc --noEmit",
        "validate": "knip --production --exclude types",
        "prepare": "husky"
    },
    "dependencies": {
        "@arcjet/redact": "^1.3.0",
        "@base-ui/react": "^1.3.0",
        "@better-auth/prisma-adapter": "^1.5.6",
        "@better-auth/stripe": "^1.5.6",
        "@braintree/sanitize-url": "^7.1.2",
        "@modelcontextprotocol/sdk": "^1.28.0",
        "@prisma/adapter-pg": "^7.6.0",
        "@prisma/client": "^7.6.0",
        "@t3-oss/env-nextjs": "^0.13.11",
        "better-auth": "^1.5.6",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "copy-to-clipboard": "^3.3.3",
        "dayjs": "^1.11.20",
        "gt-next": "^6.14.8",
        "lucide-react": "^1.7.0",
        "mcp-handler": "^1.1.0",
        "nanoid": "^5.1.7",
        "next": "16.2.1",
        "nuqs": "^2.8.9",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "server-only": "^0.0.1",
        "shadcn": "^4.1.1",
        "stripe": "^21.0.1",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.9",
        "@tailwindcss/postcss": "^4",
        "@types/bun": "^1.3.11",
        "@types/node": "^25",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "1.0.0",
        "chalk": "^5.6.2",
        "dotenv": "^17.3.1",
        "gt": "^2.13.2",
        "husky": "^9.1.7",
        "knip": "^6.1.0",
        "prisma": "^7.6.0",
        "tailwindcss": "^4",
        "typescript": "^6",
        "ultracite": "^7.4.0"
    },
    "engines": {
        "node": "24.x"
    }
}
